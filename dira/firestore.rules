rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(clinicId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/clinics/$(clinicId)/members/$(request.auth.uid));
    }

    function isAdmin(clinicId) {
      return isMember(clinicId) &&
        get(/databases/$(database)/documents/clinics/$(clinicId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /clinics/{clinicId} {
      allow create: if request.auth != null;
      allow read: if isMember(clinicId);
      allow update: if isAdmin(clinicId);

      match /members/{memberId} {
        allow read: if isMember(clinicId);
        allow create: if request.auth != null && request.auth.uid == memberId;
        allow update, delete: if isAdmin(clinicId);
      }

      match /invites/{inviteId} {
        allow read: if isMember(clinicId) ||
          (request.auth != null && resource.data.email == request.auth.token.email);
        allow create: if isAdmin(clinicId);
        allow update: if request.auth != null && resource.data.email == request.auth.token.email;
        allow delete: if isAdmin(clinicId);
      }

      match /tickets/{ticketId} {
        allow read, create, update, delete: if isMember(clinicId);

        match /comments/{commentId} {
          allow read, create: if isMember(clinicId);
        }
      }
    }
  }
}